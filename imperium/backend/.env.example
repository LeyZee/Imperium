# Environnement (development | production)
NODE_ENV=production

# JWT Secret — requis, utilisé pour signer les tokens d'authentification
# Générez une clé aléatoire : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Port du serveur (optionnel, défaut: 3001)
PORT=3001

# CORS — origine autorisée pour le frontend (requis en production cross-domain)
CORS_ORIGIN=https://app.imperaagency.com

# URL de l'application frontend (pour les liens dans les emails)
APP_URL=https://app.imperaagency.com

# Mot de passe admin par défaut (premier démarrage uniquement)
# Si non défini, un mot de passe aléatoire sera généré et affiché dans les logs
ADMIN_DEFAULT_PASSWORD=

# Secret pour l'endpoint Telegram — requis pour recevoir les rapports
# Le bot Telegram doit envoyer ce token dans le header X-Telegram-Secret
TELEGRAM_SECRET=

# Token du bot Telegram — requis pour le polling des messages
# Obtenir via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=

# SMTP — requis pour les invitations et vérifications email
# Laisser vide = fallback console.log (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Imperium <admin@impera-agency.com>
